            }

                .modal-content .form-group input:focus,
                .modal-content .form-group textarea:focus {
                    outline: none;
                    border-color: #D4AF37;
                }

            .modal-content .form-group textarea {
                min-height: 60px;
                resize: vertical;
            }

    .btn--full {
        width: 100%;
    }

    .btn--gray {
        background: #6B7280;
        color: white;
    }

