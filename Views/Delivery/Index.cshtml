@using BagguWeb.Models
@model List<Producto>
@{
    ViewData["Title"] = "Delivery";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string categoriaActiva = ViewBag.Categoria ?? "Menu";
}

<section class="delivery-wrapper">
    <div class="container">
        <h2 class="section-title">🛵 PEDIDOS A DOMICILIO</h2>

        <!-- Filtro de categorías -->
        <div class="category-tabs">
            @foreach (string cat in (string[])ViewBag.Categorias)
            {
                <a href="/Delivery?categoria=@cat"
                   class="cat-tab @(categoriaActiva == cat ? "active" : "")">
                    @cat
                </a>
            }
        </div>
        <div class="voice-transcript" id="voiceTranscript"></div>
        <button class="btn btn--sm voice-reset-btn" id="voiceResetBtn" style="display:none;" onclick="resetearBusquedaVoz()">
            ✖ Ver todo el menú
        </button>
        <!-- Grid de productos -->
        <div class="products-grid" id="productsGrid">
            @foreach (var p in Model)
            {
                <div class="product-card"
                     data-nombre="@p.Nombre"
                     data-desc="@p.Descripcion"
                     data-categoria="@p.Categoria">
                    <div class="product-icon">@p.Icono</div>
                    <h3 class="product-name">@p.Nombre</h3>
                    <p class="product-desc">@p.Descripcion</p>
                    <div class="product-prices">
                        <span class="price-offer">Bs. @p.Precio</span>
                        @if (p.PrecioOriginal.HasValue && p.PrecioOriginal.Value > 0)
                        {
                            <span class="price-original">Bs. @p.PrecioOriginal.Value</span>
                        }
                    </div>
                    <button class="btn btn--gold btn--full btn--sm"
                            onclick="agregarAlCarrito(@p.Id, '@p.Nombre', @p.Precio)">
                        ➕ Agregar
                    </button>
                </div>
            }
        </div>
    </div>
</section>

<!-- MODAL DE CONFIRMACIÓN DE PEDIDO -->
<div class="modal-overlay" id="modalPedido" style="display:none;">
    <div class="modal-content">
        <h3>📦 CONFIRMAR PEDIDO</h3>
        <form id="formPedido">
            <div class="form-group">
                <label>NOMBRE *</label>
                <input type="text" id="clienteNombre" required placeholder="Tu nombre completo" />
            </div>
            <div class="form-group">
                <label>EMAIL</label>
                <input type="email" id="clienteEmail" placeholder="tu@email.com" />
            </div>
            <div class="form-group">
                <label>TELÉFONO</label>
                <input type="tel" id="clienteTelefono" placeholder="+591 7XXXXXXX" />
            </div>
            <div class="form-group">
                <label>DIRECCIÓN DE ENTREGA *</label>
                <input type="text" id="direccion" required placeholder="Calle, número, referencia" />
            </div>
            <div class="form-group">
                <label>TOTAL</label>
                <span id="totalPedido" style="font-size:24px; font-weight:bold; color:#D4AF37;">Bs. 0.00</span>
            </div>
            <button type="submit" class="btn btn--gold btn--full">✅ CONFIRMAR PEDIDO</button>
            <button type="button" class="btn btn--gray btn--full" onclick="cerrarModal()">✕ CANCELAR</button>
        </form>
    </div>
</div>

<!-- CARRITO FLOTANTE -->
<div class="cart-panel" id="cartPanel" style="display:none;">
    <h3>🛒 Tu pedido</h3>
    <div id="cartItems"><p class="cart-empty">Tu carrito está vacío</p></div>
    <div class="cart-total">Total: <strong id="cartTotal">Bs. 0.00</strong></div>
    <button class="btn btn--gold btn--full" onclick="mostrarModal()">CONFIRMAR PEDIDO</button>
</div>

<button class="cart-fab" onclick="toggleCart()" id="cartFab">🛒 <span id="cartCount">0</span></button>

    <!-- BOTÓN FLOTANTE ASISTENTE DE VOZ -->
    <button class="voice-fab" onclick="iniciarAsistenteVoz()" id="voiceFab" title="Buscar en el menú por voz">🎤</button>

    <script>
        let carrito = [];

        /* ==================== ASISTENTE DE VOZ (Web Speech API) ==================== */

        function normalizarTexto(str) {
            return (str || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim();
        }

        function hablar(texto) {
            if (!('speechSynthesis' in window)) return;
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(texto);
            utterance.lang = 'es-ES';
            utterance.rate = 1;
            window.speechSynthesis.speak(utterance);
        }

        function iniciarAsistenteVoz() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            const fab = document.getElementById('voiceFab');
            const transcriptEl = document.getElementById('voiceTranscript');

            if (!SpeechRecognition) {
                alert('⚠️ Tu navegador no soporta reconocimiento de voz. Prueba con Google Chrome.');
                return;
            }

            const reconocimiento = new SpeechRecognition();
            reconocimiento.lang = 'es-BO';
            reconocimiento.interimResults = false;
            reconocimiento.maxAlternatives = 1;

            fab.classList.add('listening');
            transcriptEl.textContent = '🎙️ Escuchando... di el nombre de un plato';

            reconocimiento.start();

            reconocimiento.onresult = function (event) {
                const texto = event.results[0][0].transcript;
                transcriptEl.textContent = `🔎 Buscaste: "${texto}"`;
                buscarProductoPorVoz(texto);
            };

            reconocimiento.onerror = function () {
                transcriptEl.textContent = '⚠️ No pude escucharte, intenta de nuevo.';
                hablar('No pude escucharte, intenta de nuevo.');
            };

            reconocimiento.onend = function () {
                fab.classList.remove('listening');
            };
        }

        function buscarProductoPorVoz(texto) {
            const consulta = normalizarTexto(texto);
            const palabras = consulta.split(' ').filter(p => p.length > 2);
            const cards = document.querySelectorAll('#productsGrid .product-card');
            const encontrados = [];

            cards.forEach(function (card) {
                const nombre = normalizarTexto(card.dataset.nombre);
                const desc = normalizarTexto(card.dataset.desc);
                const categoria = normalizarTexto(card.dataset.categoria);

                const coincide = nombre.includes(consulta) ||
                                  consulta.includes(nombre) ||
                                  desc.includes(consulta) ||
                                  categoria.includes(consulta) ||
                                  palabras.some(p => nombre.includes(p) || desc.includes(p));

                card.style.display = coincide ? '' : 'none';
                card.classList.toggle('voice-highlight', coincide);
                if (coincide) encontrados.push(card.dataset.nombre);
            });

            document.getElementById('voiceResetBtn').style.display = 'inline-block';

            if (encontrados.length > 0) {
                const lista = encontrados.slice(0, 3).join(', ');
                hablar(`Encontré ${encontrados.length} resultado${encontrados.length > 1 ? 's' : ''} para ${texto}: ${lista}`);
            } else {
                hablar(`No encontré ningún producto relacionado con ${texto} en el menú.`);
            }
        }

        function resetearBusquedaVoz() {
            document.querySelectorAll('#productsGrid .product-card').forEach(function (card) {
                card.style.display = '';
                card.classList.remove('voice-highlight');
            });
            document.getElementById('voiceResetBtn').style.display = 'none';
            document.getElementById('voiceTranscript').textContent = '';
        }
        /* =============================================================================== */

    function agregarAlCarrito(id, nombre, precio) {
        const item = carrito.find(i => i.id === id);
        if (item) { item.cantidad++; }
        else { carrito.push({ id, nombre, precio, cantidad: 1 }); }
        actualizarCarrito();
    }

    function actualizarCarrito() {
        const items = document.getElementById('cartItems');
        const total = document.getElementById('cartTotal');
        const count = document.getElementById('cartCount');

        if (carrito.length === 0) {
            items.innerHTML = '<p class="cart-empty">Tu carrito está vacío</p>';
            total.textContent = 'Bs. 0.00';
            count.textContent = '0';
            return;
        }

        let html = '';
        let sum = 0;
        carrito.forEach(i => {
            html += `<div class="cart-item">
                <span>${i.nombre} x${i.cantidad}</span>
                <span>Bs. ${(i.precio * i.cantidad).toFixed(2)}</span>
                <button onclick="quitarItem(${i.id})">✕</button>
            </div>`;
            sum += i.precio * i.cantidad;
        });
        items.innerHTML = html;
        total.textContent = `Bs. ${sum.toFixed(2)}`;
        count.textContent = carrito.reduce((a, i) => a + i.cantidad, 0);
    }

    function quitarItem(id) {
        carrito = carrito.filter(i => i.id !== id);
        actualizarCarrito();
    }

    function toggleCart() {
        const p = document.getElementById('cartPanel');
        p.style.display = p.style.display === 'none' ? 'block' : 'none';
    }

    function mostrarModal() {
        if (carrito.length === 0) {
            alert('⚠️ Tu carrito está vacío');
            return;
        }
        const total = carrito.reduce((sum, i) => sum + i.precio * i.cantidad, 0);
        document.getElementById('totalPedido').textContent = 'Bs. ' + total.toFixed(2);
        document.getElementById('modalPedido').style.display = 'flex';
        document.getElementById('cartPanel').style.display = 'none';
    }

    function cerrarModal() {
        document.getElementById('modalPedido').style.display = 'none';
    }

    // Al confirmar el pedido
    document.getElementById('formPedido').addEventListener('submit', async function(e) {
        e.preventDefault();

        const clienteNombre = document.getElementById('clienteNombre').value.trim();
        const direccion = document.getElementById('direccion').value.trim();

        if (!clienteNombre || !direccion) {
            alert('⚠️ Complete los campos obligatorios (Nombre y Dirección)');
            return;
        }

        const pedido = {
            ClienteNombre: clienteNombre,
            ClienteEmail: document.getElementById('clienteEmail').value.trim(),
            ClienteTelefono: document.getElementById('clienteTelefono').value.trim(),
            Direccion: direccion,
            Total: carrito.reduce((sum, i) => sum + i.precio * i.cantidad, 0),
            Items: carrito.map(i => ({ ProductoId: i.id, Nombre: i.nombre, Precio: i.precio, Cantidad: i.cantidad }))
        };

        try {
            const response = await fetch('/Delivery/GuardarPedido', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(pedido)
            });

            const data = await response.json();
            alert(data.message);

            if (data.success) {
                carrito = [];
                actualizarCarrito();
                cerrarModal();
                // Recargar la página para resetear el estado
                location.reload();
            }
        } catch (error) {
            alert('❌ Error al enviar el pedido: ' + error.message);
        }
    });
</script>

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
    }

    .modal-content {
        background: white;
        padding: 30px;
        border-radius: 12px;
        max-width: 450px;
        width: 100%;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

        .modal-content h3 {
            font-family: 'Georgia', serif;
            text-align: center;
            margin-bottom: 20px;
        }

    .btn--gray {
        background: #6B7280;
        color: white;
        margin-top: 10px;
    }

        .btn--gray:hover {
            background: #4B5563;
        }
</style>